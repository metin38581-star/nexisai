# PostgreSQL (Supabase) — Vercel Production için zorunlu
# Dashboard → Project Settings → Database → Connection string → Transaction pooler (6543)
# Kullanıcı adı mutlaka: postgres.PROJECT_REF  (örn: postgres.hfrxarwwzxlxzzvfzrgk)
# Host bölgesi projenizle aynı olmalı (örn: aws-1-eu-central-1.pooler.supabase.com)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# NexisAI Hub — public makale URL tabanı (örn: https://nexisai-fawn.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase REST (tablo adları: "Campaign", "Bait")
# Dashboard → Project Settings → API → Project URL + anon public + service_role
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Merkezi GEO Dağıtım API / Webhook
NEXT_PUBLIC_GEO_API_URL=
GEO_API_TOKEN=

LLM_API_KEY=

# Sağlayıcı: google | perplexity (varsayılan) | openai
LLM_PROVIDER=google

# Model: google için gemini-2.5-flash (alternatif: gemini-1.5-pro), perplexity için sonar, openai için gpt-4o
LLM_MODEL=gemini-2.5-flash

# Google Vertex AI (LLM_PROVIDER=google iken zorunlu)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Admin paneli — virgülle ayrılmış yetkili e-posta listesi
ADMIN_EMAILS=oktay38@gmail.com
NEXT_PUBLIC_ADMIN_EMAILS=oktay38@gmail.com

# Medium native dağıtım kanalı
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_USER_ID=

# WordPress native dağıtım kanalı (Application Password gerekir)
WP_SITE_URL=https://nexisai.blog
WP_USERNAME=nexisai
WP_APP_PASSWORD=

# Otonom dağıtım kanalları (izin/üyelik gerektirmez)
TELEGRAPH_ACCESS_TOKEN=
GITHUB_TOKEN=
GITHUB_RADAR_OWNER=
GITHUB_RADAR_REPO=nexisai-radar
GITHUB_RADAR_BRANCH=main
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol
