# PostgreSQL (Supabase) — canlı veritabanı
# Runtime: transaction pooler (6543). Şema push için session pooler (5432) kullanın.
DATABASE_URL="postgresql://USER:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"
# NexisAI Hub — public makale URL tabanı (örn: https://nexisai.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase REST (tablo adları: "Campaign", "Bait")
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Merkezi GEO Dağıtım API / Webhook
NEXT_PUBLIC_GEO_API_URL=
GEO_API_TOKEN=

LLM_API_KEY=

# Sağlayıcı: google | perplexity (varsayılan) | openai
LLM_PROVIDER=google

# Model: google için gemini-2.5-flash (alternatif: gemini-1.5-pro), perplexity için sonar, openai için gpt-4o
LLM_MODEL=gemini-2.5-flash

# Google Vertex AI (LLM_PROVIDER=google iken zorunlu)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
