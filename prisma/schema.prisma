// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  id        String   @id @default(uuid())
  balance   Float    @default(500.0)
  updatedAt DateTime @default(now()) @updatedAt
}

model Campaign {
  id            String    @id @default(uuid())
  userId        String?   @map("userId")
  sehir         String
  sektor        String
  markaAdi      String
  skor          Int
  gunlukButce   Float     @default(250)
  gunSayisi     Int       @default(7)
  agresiflik         String    @default("Orta")
  makaleSayisi       Int       @default(2)
  radarSikligi       String    @default("24 Saat")
  radarSikligiDakika Int       @default(1440)
  isOptimized        Boolean   @default(false)
  lastCheckedAt DateTime?
  llmFeedback   String?   @default("Yapay zeka taraması bekleniyor...")
  liveUrl           String?   @map("live_url")
  externalLiveUrl   String?   @map("external_live_url")
  createdAt     DateTime  @default(now())
  baits         Bait[]
  radarLogs     CampaignRadarLog[]
}

model MarketIntelligence {
  id        String   @id @default(uuid())
  sector    String
  city      String
  questions Json
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([sector, city])
  @@map("MarketIntelligence")
}

model CampaignRadarLog {
  id           String   @id @default(uuid())
  campaignId   String
  scanResult   Json
  shareOfVoice Int
  createdAt    DateTime @default(now())
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("CampaignRadarLog")
}

model Bait {
  id               String   @id @default(uuid())
  campaignId       String
  baslik           String
  icerik           String
  slug             String   @unique
  platform         String   @default("PBN")
  yayinlandi       Boolean  @default(false)
  status           String   @default("PENDING")
  liveUrl          String?  @map("live_url")
  externalLiveUrl  String?  @map("external_live_url")
  createdAt        DateTime @default(now())
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
