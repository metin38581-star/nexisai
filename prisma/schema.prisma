// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  /// Supabase auth.users id — cüzdan satırı kullanıcı başına bir adet
  id        String   @id
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt

  @@map("Wallet")
}

// Eski UserWallet modeli kaldırıldı — tüm sorgular prisma.wallet üzerinden çalışır.

model RegisteredBusiness {
  id              String   @id @default(uuid())
  businessName    String   @map("business_name")
  normalizedName  String   @unique @map("normalized_name")
  createdByUserId String   @map("created_by_user_id")
  isTrialUsed     Boolean  @default(false) @map("is_trial_used")
  createdAt       DateTime @default(now())

  @@map("RegisteredBusiness")
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  codeHash  String   @map("code_hash")
  purpose   String   @default("register")
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("OtpVerification")
}

model CampaignGrowthLoop {
  id               String    @id @default(uuid())
  campaignId       String    @unique @map("campaignId")
  userId           String    @map("userId")
  emailScheduledAt DateTime  @map("email_scheduled_at")
  emailSentAt      DateTime? @map("email_sent_at")
  scoresUpdatedAt  DateTime? @map("scores_updated_at")
  questionScores   Json      @map("question_scores")
  createdAt        DateTime  @default(now())
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("CampaignGrowthLoop")
}

model IyzicoCheckout {
  id             String   @id @default(uuid())
  userId         String   @map("userId")
  token          String?  @unique
  conversationId String?  @unique @map("conversation_id")
  amount         Float
  currency       String   @default("TRY")
  status         String   @default("pending")
  campaignDraft  Json?    @map("campaign_draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@map("IyzicoCheckout")
}

model Campaign {
  id            String    @id @default(uuid())
  userId        String?   @map("userId")
  sehir         String
  sektor        String
  markaAdi      String
  skor          Int
  gunlukButce   Float     @default(250)
  gunSayisi     Int       @default(7)
  agresiflik         String    @default("Orta")
  makaleSayisi       Int       @default(2)
  radarSikligi       String    @default("24 Saat")
  radarSikligiDakika Int       @default(1440)
  isOptimized        Boolean   @default(false)
  lastCheckedAt DateTime?
  llmFeedback   String?   @default("Yapay zeka taraması bekleniyor...")
  liveUrl           String?   @map("live_url")
  externalLiveUrl   String?   @map("external_live_url")
  wordpressUrl      String?   @map("wordpress_url")
  businessDomain String?   @map("business_domain")
  createdAt     DateTime  @default(now())
  baits         Bait[]
  intents       CampaignIntent[]
  payments      Payment[]
  radarLogs     CampaignRadarLog[]
  growthLoop    CampaignGrowthLoop?
  hubAnswers    HubAnswer[]
  campaignLog   CampaignLog?
}

model CampaignLog {
  id              String   @id @default(uuid())
  campaignId      String   @unique @map("campaign_id")
  userId          String   @map("user_id")
  userEmail       String   @map("user_email")
  businessName    String   @map("business_name")
  sector          String
  sectorLabel     String?  @map("sector_label")
  city            String
  walletBalance   Float    @default(0) @map("wallet_balance")
  amountSpent     Float    @default(0) @map("amount_spent")
  amountDeposited Float    @default(0) @map("amount_deposited")
  wordpressUrl    String?  @map("wordpress_url")
  forumUrl            String?  @map("forum_url")
  blogUrl             String?  @map("blog_url")
  primaryAuthorityUrl String?  @map("primary_authority_url")
  businessDomain      String?  @map("business_domain")
  createdAt           DateTime @default(now()) @map("created_at")
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([city])
  @@index([sector])
  @@map("CampaignLog")
}

model MarketIntelligence {
  id        String   @id @default(uuid())
  sector    String
  city      String
  questions Json
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([sector, city])
  @@map("MarketIntelligence")
}

model CampaignRadarLog {
  id           String   @id @default(uuid())
  campaignId   String
  scanResult   Json
  shareOfVoice Int
  createdAt    DateTime @default(now())
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("CampaignRadarLog")
}

model Bait {
  id               String   @id @default(uuid())
  campaignId       String
  baslik           String
  icerik           String
  slug             String   @unique
  platform         String   @default("PBN")
  yayinlandi       Boolean  @default(false)
  status           String   @default("PENDING")
  liveUrl          String?  @map("live_url")
  externalLiveUrl  String?  @map("external_live_url")
  wpUrl            String?  @map("wp_url")
  blogUrl          String?  @map("blog_url")
  forumUrl         String?  @map("forum_url")
  devToUrl         String?  @map("dev_to_url")
  createdAt        DateTime @default(now())
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  intent           CampaignIntent?
}

model CampaignIntent {
  id              String   @id @default(uuid())
  campaignId      String   @map("campaignId")
  question        String
  simulatedAnswer String
  sortOrder       Int      @default(0)
  baitId          String?  @unique @map("baitId")
  createdAt       DateTime @default(now())
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  bait            Bait?    @relation(fields: [baitId], references: [id], onDelete: SetNull)

  @@map("CampaignIntent")
}

model Payment {
  id                 String    @id @default(uuid())
  userId             String    @map("userId")
  amount             Float
  currency           String    @default("USD")
  status             String    @default("success")
  provider           String    @default("internal")
  providerStatusCode String?   @map("provider_status_code")
  description        String?
  campaignId         String?   @map("campaignId")
  createdAt          DateTime  @default(now())
  campaign           Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("Payment")
}

model QuestionHub {
  id             String      @id @default(cuid())
  slug           String      @unique
  question       String
  coreQuestionId String?     @map("core_question_id")
  answers        HubAnswer[]
  createdAt      DateTime    @default(now())

  @@index([coreQuestionId])
  @@map("QuestionHub")
}

model HubAnswer {
  id           String      @id @default(cuid())
  questionId   String      @map("question_id")
  questionHub  QuestionHub @relation(fields: [questionId], references: [id], onDelete: Cascade)
  campaignId   String      @map("campaign_id")
  campaign     Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  username     String
  content      String
  upvotes      Int         @default(0)
  isFeatured   Boolean     @default(false) @map("is_featured")
  createdAt    DateTime    @default(now())

  @@index([questionId, isFeatured, createdAt])
  @@index([campaignId])
  @@map("HubAnswer")
}

model CampaignProcessingState {
  campaignId String   @id @map("campaign_id")
  status     String   @default("started")
  logs       Json     @default("[]")
  result     Json?
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([status], map: "CampaignProcessingState_status_idx")
  @@map("CampaignProcessingState")
}
