// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  id             String   @id @default(uuid())
  userId         String?  @unique @map("userId")
  balance        Float    @default(0)
  welcomeGranted Boolean  @default(false) @map("welcome_granted")
  hasPaidTopUp   Boolean  @default(false) @map("has_paid_top_up")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@map("Wallet")
}

// Eski UserWallet modeli kaldırıldı — tüm sorgular prisma.wallet üzerinden çalışır.

model RegisteredBusiness {
  id              String   @id @default(uuid())
  businessName    String   @map("business_name")
  normalizedName  String   @unique @map("normalized_name")
  createdByUserId String   @map("created_by_user_id")
  isTrialUsed     Boolean  @default(false) @map("is_trial_used")
  createdAt       DateTime @default(now())

  @@map("RegisteredBusiness")
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  codeHash  String   @map("code_hash")
  purpose   String   @default("register")
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("OtpVerification")
}

model CampaignGrowthLoop {
  id               String    @id @default(uuid())
  campaignId       String    @unique @map("campaignId")
  userId           String    @map("userId")
  emailScheduledAt DateTime  @map("email_scheduled_at")
  emailSentAt      DateTime? @map("email_sent_at")
  scoresUpdatedAt  DateTime? @map("scores_updated_at")
  questionScores   Json      @map("question_scores")
  createdAt        DateTime  @default(now())
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("CampaignGrowthLoop")
}

model IyzicoCheckout {
  id             String   @id @default(uuid())
  userId         String   @map("userId")
  token          String?  @unique
  conversationId String?  @unique @map("conversation_id")
  amount         Float
  currency       String   @default("TRY")
  status         String   @default("pending")
  campaignDraft  Json?    @map("campaign_draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@map("IyzicoCheckout")
}

model Campaign {
  id            String    @id @default(uuid())
  userId        String?   @map("userId")
  sehir         String
  sektor        String
  markaAdi      String
  skor          Int
  gunlukButce   Float     @default(250)
  gunSayisi     Int       @default(7)
  agresiflik         String    @default("Orta")
  makaleSayisi       Int       @default(2)
  radarSikligi       String    @default("24 Saat")
  radarSikligiDakika Int       @default(1440)
  isOptimized        Boolean   @default(false)
  lastCheckedAt DateTime?
  llmFeedback   String?   @default("Yapay zeka taraması bekleniyor...")
  liveUrl           String?   @map("live_url")
  externalLiveUrl   String?   @map("external_live_url")
  wordpressUrl      String?   @map("wordpress_url")
  createdAt     DateTime  @default(now())
  baits         Bait[]
  intents       CampaignIntent[]
  payments      Payment[]
  radarLogs     CampaignRadarLog[]
  growthLoop    CampaignGrowthLoop?
}

model MarketIntelligence {
  id        String   @id @default(uuid())
  sector    String
  city      String
  questions Json
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([sector, city])
  @@map("MarketIntelligence")
}

model CampaignRadarLog {
  id           String   @id @default(uuid())
  campaignId   String
  scanResult   Json
  shareOfVoice Int
  createdAt    DateTime @default(now())
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("CampaignRadarLog")
}

model Bait {
  id               String   @id @default(uuid())
  campaignId       String
  baslik           String
  icerik           String
  slug             String   @unique
  platform         String   @default("PBN")
  yayinlandi       Boolean  @default(false)
  status           String   @default("PENDING")
  liveUrl          String?  @map("live_url")
  externalLiveUrl  String?  @map("external_live_url")
  createdAt        DateTime @default(now())
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  intent           CampaignIntent?
}

model CampaignIntent {
  id              String   @id @default(uuid())
  campaignId      String   @map("campaignId")
  question        String
  simulatedAnswer String
  sortOrder       Int      @default(0)
  baitId          String?  @unique @map("baitId")
  createdAt       DateTime @default(now())
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  bait            Bait?    @relation(fields: [baitId], references: [id], onDelete: SetNull)

  @@map("CampaignIntent")
}

model Payment {
  id                 String    @id @default(uuid())
  userId             String    @map("userId")
  amount             Float
  currency           String    @default("USD")
  status             String    @default("success")
  provider           String    @default("internal")
  providerStatusCode String?   @map("provider_status_code")
  description        String?
  campaignId         String?   @map("campaignId")
  createdAt          DateTime  @default(now())
  campaign           Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("Payment")
}
